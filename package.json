{
  "name": "bonfisoft-development-tracker",
  "displayName": "BonfiSoft Development Tracker",
  "description": "Project-local issue tracking with git integration",
  "version": "0.1.0",
  "publisher": "bonfisoft",
  "license": "AGPL-3.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "issues",
    "tracking",
    "project management",
    "tasks",
    "bugs"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bonfisoftIssuesSidebar",
          "title": "Issues",
          "icon": "resources/issues.svg"
        }
      ]
    },
    "views": {
      "bonfisoftIssuesSidebar": [
        {
          "id": "bonfisoftIssues",
          "name": "Issues",
          "contextualTitle": "BonfiSoft Issues"
        }
      ]
    },
    "commands": [
      {
        "command": "bonfisoft-issues.refreshIssues",
        "title": "Refresh Issues",
        "icon": "$(refresh)",
        "category": "BonfiSoft Issues"
      },
      {
        "command": "bonfisoft-issues.createIssue",
        "title": "Create Issue",
        "icon": "$(add)",
        "category": "BonfiSoft Issues"
      },
      {
        "command": "bonfisoft-issues.viewIssue",
        "title": "View Issue",
        "category": "BonfiSoft Issues"
      },
      {
        "command": "bonfisoft-issues.editIssue",
        "title": "Edit Issue",
        "category": "BonfiSoft Issues"
      },
      {
        "command": "bonfisoft-issues.deleteIssue",
        "title": "Delete Issue",
        "category": "BonfiSoft Issues"
      },
      {
        "command": "bonfisoft-issues.searchIssues",
        "title": "Search Issues",
        "category": "BonfiSoft Issues"
      },
      {
        "command": "bonfisoft-issues.closeIssue",
        "title": "Close Issue",
        "category": "BonfiSoft Issues"
      },
      {
        "command": "bonfisoft-issues.resolveIssue",
        "title": "Resolve Issue",
        "category": "BonfiSoft Issues"
      },
      {
        "command": "bonfisoft-issues.reopenIssue",
        "title": "Reopen Issue",
        "category": "BonfiSoft Issues"
      },
      {
        "command": "bonfisoft-issues.filterIssues",
        "title": "Filter Issues",
        "icon": "$(filter)",
        "category": "BonfiSoft Issues"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "bonfisoft-issues.createIssue",
          "when": "view == bonfisoftIssues",
          "group": "navigation"
        },
        {
          "command": "bonfisoft-issues.filterIssues",
          "when": "view == bonfisoftIssues",
          "group": "navigation"
        },
        {
          "command": "bonfisoft-issues.refreshIssues",
          "when": "view == bonfisoftIssues",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "bonfisoft-issues.viewIssue",
          "when": "view == bonfisoftIssues && viewItem == issue",
          "group": "inline"
        },
        {
          "command": "bonfisoft-issues.editIssue",
          "when": "view == bonfisoftIssues && viewItem == issue",
          "group": "issue@1"
        },
        {
          "command": "bonfisoft-issues.closeIssue",
          "when": "view == bonfisoftIssues && viewItem == issue",
          "group": "issue@2"
        },
        {
          "command": "bonfisoft-issues.resolveIssue",
          "when": "view == bonfisoftIssues && viewItem == issue",
          "group": "issue@3"
        },
        {
          "command": "bonfisoft-issues.reopenIssue",
          "when": "view == bonfisoftIssues && viewItem == issue",
          "group": "issue@4"
        },
        {
          "command": "bonfisoft-issues.deleteIssue",
          "when": "view == bonfisoftIssues && viewItem == issue",
          "group": "issue@9"
        }
      ]
    },
    "keybindings": [
      {
        "command": "bonfisoft-issues.createIssue",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i"
      },
      {
        "command": "bonfisoft-issues.searchIssues",
        "key": "ctrl+alt+shift+f",
        "mac": "cmd+alt+shift+f"
      }
    ],
    "configuration": {
      "title": "BonfiSoft Development Tracker",
      "properties": {
        "bonfisoft-issues.storageLocation": {
          "type": "string",
          "default": "workspace",
          "enum": ["workspace", "global"],
          "description": "Where to store issues: workspace (.vscode/issues/) or global (VS Code global storage)"
        },
        "bonfisoft-issues.author": {
          "type": "string",
          "default": "",
          "description": "Your name or username - used as the reporter on new issues"
        },
        "bonfisoft-issues.defaultIssueType": {
          "type": "string",
          "default": "bug",
          "enum": ["bug", "feature", "task", "enhancement", "question", "documentation", "other"],
          "description": "Default issue type pre-selected when creating a new issue"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --production",
    "esbuild-base": "node esbuild.js",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.118.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  }
}
